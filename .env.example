# ============================================================
# LLM Provider 选择（dashscope / spark）
# ============================================================
# 切换方法：改 LLM_PROVIDER 即可。LLM 调用会走对应后端。
# ⚠️ 重要：Embedding 和 ASR 始终使用 DashScope，切到 Spark 后仍需保留 DASHSCOPE_API_KEY。
LLM_PROVIDER=dashscope

# --- DashScope (阿里云通义千问) ---
DASHSCOPE_API_KEY=sk-your-dashscope-api-key
OPENAI_API_KEY=
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# --- 讯飞星火 Spark (HTTP OpenAI 兼容) ---
# 切 Spark 时取消下面三行注释，并保持上面 DASHSCOPE_API_KEY 不动。
# SPARK_API_KEY=你的APIpassword（从 console.xfyun.cn 获取）
# SPARK_BASE_URL=https://spark-api-open.xf-yun.com/v2
# SPARK_MODEL=spark-x

# Model Config
LLM_MODEL=qwen3-max
EMBEDDING_MODEL=text-embedding-v4

# DashScope ASR
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1
ASR_MODEL=paraformer-v2
ASR_TIMEOUT=600
ASR_MODEL_LOCAL=paraformer-realtime-v2
ASR_INPUT_FORMAT=pcm

# App Config
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/bilimind.db

# ChromaDB
CHROMA_PERSIST_DIRECTORY=./data/chroma_db

# Knowledge Graph
GRAPH_PERSIST_PATH=./data/graph.json

# Knowledge Extraction
EXTRACTION_MIN_CONFIDENCE=0.3
TREE_MIN_CONFIDENCE=0.4
EXTRACTION_SEGMENT_MERGE_SECONDS=30.0

# Lightweight ML Models
MODEL_ARTIFACT_DIR=./data/models
EVIDENCE_RANKER_MODEL_PATH=./data/models/evidence_ranker.json
ORGANIZER_CLASSIFIER_MODEL_PATH=./data/models/organizer_classifier.json
EVIDENCE_RANKER_ENABLED=true
ORGANIZER_CLASSIFIER_ENABLED=true
